generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Main Opportunities (Jobs & Internships combined)
model Opportunity {
  id           String   @id @default(cuid())
  slug         String   @unique

  // BASIC INFO
  title        String
  company      String
  companyLogo  String?
  aboutCompany String?

  // JOB TYPE
  type         String   // "job" | "internship"
  workMode     String   // "remote" | "onsite" | "hybrid"
  location     String

  // CONDITIONAL FIELDS
  experience   String?  // for jobs (e.g., "0-2 years")
  duration     String?  // for internships (e.g., "3 months")

  // PAY
  salary       String?  // ₹4–8 LPA or ₹15,000/month

  // SKILLS
  skills       String[]

  // DETAIL PAGE CONTENT
  overview         String?
  responsibilities String?
  qualifications   String?
  benefits         String?

  // APPLY
  applyLink    String

  // STATUS FLAGS
  isNew        Boolean  @default(true)
  isVerified   Boolean  @default(false)
  isTrending   Boolean  @default(false)
  isActivelyHiring Boolean @default(true)
  published    Boolean  @default(true)

  // DATES
  postedAt     DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deadline     DateTime? // Application deadline

  // COUNTERS
  views        Int      @default(0)
  applyClicks  Int      @default(0)

  // RELATIONS
  viewsLog     OpportunityView[]
  clicksLog    OpportunityClick[]

  @@index([type])
  @@index([location])
  @@index([workMode])
  @@index([postedAt])
  @@index([isTrending])
  @@index([isVerified])
  @@index([published])
}

// Anonymous view tracking for opportunities
model OpportunityView {
  id            String   @id @default(cuid())
  opportunityId String
  sessionId     String?
  viewedAt      DateTime @default(now())
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@index([opportunityId])
  @@index([viewedAt])
  @@index([sessionId])
}

// Anonymous click tracking for opportunities
model OpportunityClick {
  id            String   @id @default(cuid())
  opportunityId String
  sessionId     String?
  clickedAt     DateTime @default(now())
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@index([opportunityId])
  @@index([clickedAt])
  @@index([sessionId])
}

// Public stats for homepage
model SystemStat {
  id        String   @id @default(cuid())
  label     String   // "Active Opportunities", "Companies", etc.
  value     String
  icon      String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

// Learning resources
model CareerResource {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  excerpt       String
  content       String?
  category      String   // "resume", "interview", "skills", etc.
  coverImage    String?
  published     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  fileUrl       String?
  link          String?
  type          String?  @default("text")
  downloadCount Int      @default(0)

  @@index([category])
  @@index([published])
}

// Visitor analytics
model Visitor {
  id        String   @id @default(cuid())
  sessionId String
  page      String?
  referrer  String?
  userAgent String?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([createdAt])
  @@index([page])
}

// Contact form submissions
model ContactMessage {
  id        String    @id @default(cuid())
  name      String
  email     String
  userType  String    // "student", "professional", "employer"
  subject   String
  message   String
  company   String?
  createdAt DateTime  @default(now())
  status    String    @default("NEW") // "NEW", "READ", "REPLIED", "ARCHIVED"
  reply     String?
  repliedAt DateTime?
  repliedBy String?

  @@index([status])
  @@index([createdAt])
}

// Admin users
model Admin {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String?
  role      String    @default("ADMIN") // "ADMIN", "SUPER_ADMIN"
  createdAt DateTime  @default(now())
  lastLogin DateTime?

  @@index([email])
}

// Daily stats for analytics dashboard (UPDATED with blog fields)
model DailyStat {
  id            String   @id @default(cuid())
  date          DateTime @unique
  totalVisitors Int      @default(0)
  totalViews    Int      @default(0)
  totalClicks   Int      @default(0)
  applications  Int      @default(0)
  newSubscribers Int     @default(0)
  
  // Blog specific stats
  blogViews       Int      @default(0)
  blogClicks      Int      @default(0)
  uniqueBlogReaders Int    @default(0)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([date])
}

// BLOG MODELS - Complete blog analytics system

model Blog {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String?
  excerpt     String?
  coverImage  String?
  author      String?  @default("Admin")
  category    String?
  tags        String[]
  published   Boolean  @default(true)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Analytics counters
  views       Int      @default(0)
  clicks      Int      @default(0)
  avgReadTime Int?     // Average time spent reading in seconds
  
  // Relations
  viewsLog    BlogView[]
  clicksLog   BlogClick[]
  
  @@index([slug])
  @@index([published])
  @@index([category])
  @@index([publishedAt])
}

model BlogView {
  id        String   @id @default(cuid())
  blogId    String
  sessionId String?
  ipAddress String?
  userAgent String?
  referrer  String?
  readTime  Int?     // Time spent on page in seconds
  viewedAt  DateTime @default(now())
  
  blog      Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)
  
  @@index([blogId])
  @@index([sessionId])
  @@index([viewedAt])
}

model BlogClick {
  id        String   @id @default(cuid())
  blogId    String
  sessionId String?
  targetUrl String   // Where the click went (external link, internal link, etc.)
  linkText  String?  // Text of the clicked link
  linkType  String?  // "external", "internal", "download", etc.
  clickedAt DateTime @default(now())
  
  blog      Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)
  
  @@index([blogId])
  @@index([sessionId])
  @@index([clickedAt])
}

// NEWSLETTER / EMAIL SUBSCRIBERS
model Subscriber {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?   // Optional: subscriber's name
  status        String    @default("ACTIVE") // "ACTIVE", "UNSUBSCRIBED", "BOUNCED", "COMPLAINED"
  subscribedAt  DateTime  @default(now())
  unsubscribedAt DateTime?
  ipAddress     String?   // IP address at subscription time
  userAgent     String?   // Browser/device info
  source        String?   // Where they subscribed from (footer, popup, etc.)
  
  // Email marketing preferences
  preferences   Json?     // Store preferences as JSON (categories, frequency, etc.)
  
  // Job & Internship Preferences
  interestedIn  String?   // "jobs", "internships", or null (can also be comma-separated if multiple allowed)
  frequency     String?   // "daily", "weekly", "monthly"
  
  // Tracking
  lastEmailSent DateTime?
  emailCount    Int       @default(0)
  openCount     Int       @default(0)
  clickCount    Int       @default(0)
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  newsletterEmails NewsletterEmail[]
  emailLogs        EmailLog[]

  @@index([email])
  @@index([status])
  @@index([subscribedAt])
  @@index([interestedIn])
  @@index([frequency])
}

// Newsletter campaigns (for admin to send emails)
model NewsletterCampaign {
  id            String    @id @default(cuid())
  title         String
  subject       String
  content       String    // Email content (HTML)
  previewText   String?   // Preheader text
  status        String    @default("DRAFT") // "DRAFT", "SENT", "SCHEDULED", "CANCELLED"
  scheduledFor  DateTime? // When to send
  sentAt        DateTime?
  
  // Targeting
  targetAudience String?  // "all", "active", "inactive", etc.
  
  // Stats
  totalSent     Int       @default(0)
  totalOpened   Int       @default(0)
  totalClicked  Int       @default(0)
  totalUnsubscribed Int   @default(0)
  
  createdBy     String?   // Admin ID who created
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  emails        NewsletterEmail[]

  @@index([status])
  @@index([sentAt])
}

// Individual emails sent to subscribers
model NewsletterEmail {
  id             String    @id @default(cuid())
  campaignId     String
  subscriberId   String
  status         String    @default("PENDING") // "PENDING", "SENT", "OPENED", "CLICKED", "BOUNCED", "UNSUBSCRIBED"
  sentAt         DateTime?
  openedAt       DateTime?
  clickedAt      DateTime?
  openedCount    Int       @default(0)
  clickedCount   Int       @default(0)
  
  // Tracking
  userAgent      String?
  ipAddress      String?
  
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  campaign       NewsletterCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  subscriber     Subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([subscriberId])
  @@index([status])
  @@index([sentAt])
}

// Email logs for debugging
model EmailLog {
  id           String    @id @default(cuid())
  subscriberId String
  emailType    String    // "WELCOME", "NEWSLETTER", "DIGEST", "ALERT"
  subject      String
  status       String    // "SENT", "FAILED", "OPENED", "CLICKED"
  errorMessage String?
  sentAt       DateTime  @default(now())
  
  subscriber   Subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  @@index([subscriberId])
  @@index([sentAt])
  @@index([status])
}